# --- LLM Provider (Hot-Swap) ------------------------------------------------

LLM_PROVIDER=ollama

# Ollama Settings (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# Gemini Settings (used when LLM_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Embedding Provider ------------------------------------------
# Supported: "sentence-transformers" (local) | "ollama" (local) | "gemini" (cloud)
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Hardware Device Control -------------------------------------------------
# Supported: "cpu" | "cuda" | "mps" (Apple Silicon)
# Default "cpu" = an toàn cho laptop sinh viên, nhường VRAM cho Ollama.
# Đổi sang "cuda" nếu có GPU xịn (≥8GB VRAM).
EMBEDDING_DEVICE=cpu
DOCLING_DEVICE=cpu
RERANKER_DEVICE=cpu

# --- CORS  ------------------------------------------------
# Comma-separated list of allowed origins for CORS.
CORS_ORIGINS=http://localhost:5173,http://localhost:8501

# --- API Runtime -------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# --- Database ----------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./data/history.db
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=rag_documents
LIGHTRAG_WORKING_DIR=./data/lightrag
UPLOAD_DIR=./data/uploads

# --- Upload Validation --------------------------------------------------------
MAX_UPLOAD_SIZE_MB=50
ALLOWED_UPLOAD_MIME_TYPES=application/pdf,text/plain,text/markdown,text/csv,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/msword

# --- Retrieval Tuning -------------------------------------------------------
RETRIEVAL_TOP_K=5
RERANKER_TOP_K=3
RERANKER_MODEL=ms-marco-MultiBERT-L-12
CHUNK_SIZE=512
CHUNK_OVERLAP=50
