# ------------------------------------------------------------------------------
# DATABASE & SERVER
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://anhquan:anhquandeptrai@localhost:5433/graprag
CHROMA_HOST=localhost
CHROMA_PORT=8002
CORS_ORIGINS=["http://localhost:5174","http://localhost:3000"]

# ------------------------------------------------------------------------------
# API KEYS
# ------------------------------------------------------------------------------
GOOGLE_AI_API_KEY=

# ------------------------------------------------------------------------------
# LLM PROVIDER & CONFIG
# ------------------------------------------------------------------------------
# Provider selection: "gemini" | "ollama"
LLM_PROVIDER=ollama
LLM_TIMEOUT=720

# --- Ollama (Active) ---
OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen3.5:4b
OLLAMA_MODEL=qwen3.5:4b
OLLAMA_ENABLE_THINKING=false

# Recommended alternative Ollama models:
# OLLAMA_MODEL=qwen3.5:9b
# OLLAMA_MODEL=gemma3:12b
# Text only model
# OLLAMA_MODEL=kamekichi128/qwen3-4b-instruct-2507

# --- Gemini (Inactive) ---
# LLM_MODEL_FAST=gemini-2.5-flash
# Thinking level for Gemini 3.x "minimal" | "low" | "medium" | "high"
# Gemini 2.5 uses thinking_budget_tokens automatically (this setting is ignored)
# LLM_THINKING_LEVEL=medium
# Gemini 2.5 Flash: up to 8192, Gemini 3.1 Flash-Lite: up to 65536
# LLM_MAX_OUTPUT_TOKENS=8192

# ------------------------------------------------------------------------------
# EMBEDDING & VECTOR MODELS
# ------------------------------------------------------------------------------
# 1. Base RAG Embedding
NEXUSRAG_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# 2. Knowledge Graph (KG) Embedding
# Provider: "ollama" | "gemini"| "sentence_transformers"
# KG_EMBEDDING_PROVIDER=ollama
# KG_EMBEDDING_MODEL=bge-m3:latest
# KG_EMBEDDING_DIMENSION=1024 

KG_EMBEDDING_PROVIDER=ollama
KG_EMBEDDING_MODEL=nomic-embed-text:latest
KG_EMBEDDING_DIMENSION=768

# KG_EMBEDDING_PROVIDER=ollama
# KG_EMBEDDING_MODEL=mxbai-embed-large:latest
# KG_EMBEDDING_DIMENSION=1024

# Recommended:
# --- Gemini ---
# KG_EMBEDDING_PROVIDER=gemini
# KG_EMBEDDING_MODEL=gemini-embedding-2-preview
# KG_EMBEDDING_DIMENSION=3072

# KG_EMBEDDING_PROVIDER=gemini
# KG_EMBEDDING_MODEL=gemini-embedding-001
# KG_EMBEDDING_DIMENSION=3072

# --- Sentence Transformers ---
# KG_EMBEDDING_PROVIDER=sentence_transformers
# KG_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# KG_EMBEDDING_DIMENSION=384

# --- Ollama ---
# KG_EMBEDDING_PROVIDER=ollama
# KG_EMBEDDING_MODEL=mxbai-embed-large
# KG_EMBEDDING_DIMENSION=1024

# ------------------------------------------------------------------------------
# NEXUSRAG CORE & KNOWLEDGE GRAPH (KG)
# ------------------------------------------------------------------------------
NEXUSRAG_ENABLED=true
NEXUSRAG_ENABLE_KG=true
NEXUSRAG_KG_LANGUAGE=Vietnamese 
NEXUSRAG_KG_ENTITY_TYPES=["Organization","Person","Product","Location","Event","Financial_Metric","Technology","Date","Regulation"]

# KG Extraction Method: "llm" | "specialized"
KG_EXTRACTION_METHOD=specialized
NEXUSRAG_KG_GLINER_MODEL=urchade/gliner_multi-v2.1
NEXUSRAG_KG_RELATION_MODEL=Babelscape/mrebel-large

# ------------------------------------------------------------------------------
# DOCUMENT PARSER & ENRICHMENT
# ------------------------------------------------------------------------------
# Parser: "docling" (Heavy GPU) | "marker" (Lighter ~2-4GB, better math/LaTeX)
NEXUSRAG_DOCUMENT_PARSER=docling
# NEXUSRAG_MARKER_USE_LLM=false

NEXUSRAG_ENABLE_FORMULA_ENRICHMENT=true
NEXUSRAG_ENABLE_IMAGE_EXTRACTION=false
NEXUSRAG_ENABLE_IMAGE_CAPTIONING=false
NEXUSRAG_ENABLE_TABLE_CAPTIONING=false 

# ------------------------------------------------------------------------------
# CHUNKING & RETRIEVAL (RERANKER)
# ------------------------------------------------------------------------------
NEXUSRAG_CHUNK_MAX_TOKENS=500
NEXUSRAG_KG_CHUNK_TOKEN_SIZE=500

NEXUSRAG_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
NEXUSRAG_RERANKER_TOP_K=7
NEXUSRAG_MIN_RELEVANCE_SCORE=0.15
NEXUSRAG_VECTOR_PREFETCH=20

# ------------------------------------------------------------------------------
# REWRITE
# ------------------------------------------------------------------------------
NEXUSRAG_ENABLE_REWRITE_QUESTION=true

# ------------------------------------------------------------------------------
# DEDUPLICATION (CHỐNG TRÙNG LẶP)
# ------------------------------------------------------------------------------
NEXUSRAG_DEDUP_ENABLED=true
NEXUSRAG_DEDUP_MIN_CHUNK_LENGTH=50
NEXUSRAG_DEDUP_NEAR_THRESHOLD=0.85

# Processing timeout — stale documents auto-recover to FAILED after this many minutes
# NEXUSRAG_PROCESSING_TIMEOUT_MINUTES=10
